# Azure AD / Entra ID (OAuth2 client credentials)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Azure API Management
APIM_ENDPOINT=https://your-apim-gateway.azure-api.net
APIM_SCOPE=api://your-apim-app-id/.default

# Azure Key Vault
AZURE_KEYVAULT_NAME=your-keyvault-name

# Azure OpenAI (deployment names — not secrets)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-06-01

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_KEY=your-azure-search-admin-key
AZURE_SEARCH_INDEX_NAME=rag-index
